rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    match /worksheets/{userId} {
      // Izinkan baca jika ID dokumen sesuai dengan UID pengguna yang sedang login
      allow read: if isSignedIn() && request.auth.uid == userId;
      
      // Pembantu validasi skema
      function isValidWorksheet(data) {
        return data.userId == request.auth.uid
          && data.header is map
          && data.persons is list
          && data.updatedAt is timestamp
          && data.userEmail is string
          && data.keys().hasAll(['header', 'persons', 'userId', 'userEmail', 'updatedAt'])
          && data.keys().size() == 5;
      }

      allow create: if isSignedIn() 
        && request.auth.uid == userId
        && isValidWorksheet(request.resource.data)
        && request.resource.data.updatedAt == request.time;
      
      allow update: if isSignedIn() 
        && request.auth.uid == userId
        && isValidWorksheet(request.resource.data)
        && request.resource.data.updatedAt == request.time;
        
      allow delete: if isSignedIn() && request.auth.uid == userId;
    }
  }
}

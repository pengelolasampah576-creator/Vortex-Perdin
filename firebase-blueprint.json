{
  "entities": {
    "Worksheet": {
      "title": "Worksheet",
      "description": "User's perdin worksheet data",
      "type": "object",
      "properties": {
        "header": { "type": "object" },
        "persons": { "type": "array" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["header", "persons", "userId", "userEmail", "updatedAt"]
    }
  },
  "firestore": {
    "/worksheets/{worksheetId}": {
      "schema": "Worksheet",
      "description": "Stored worksheets for users"
    }
  }
}
